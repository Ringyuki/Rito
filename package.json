{
  "name": "Rito",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:pack-check": "node ./scripts/check-release-tarballs.mjs",
    "version-packages": "changeset version",
    "release:publish": "pnpm publish -r",
    "release:ci": "pnpm run check && pnpm release:pack-check && pnpm release:publish --tag next",
    "dev": "pnpm -r --parallel run dev",
    "dev:reader": "pnpm --filter @ritojs/reader dev",
    "dev:rito": "pnpm --filter ./packages/rito dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
