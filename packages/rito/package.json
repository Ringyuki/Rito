{
  "name": "@rito/core",
  "type": "module",
  "version": "0.6.0",
  "description": "Canvas-based EPUB rendering engine",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "homepage": "https://github.com/Ringyuki/Rito/tree/master/packages/rito#readme",
  "bugs": {
    "url": "https://github.com/Ringyuki/Rito/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ringyuki/Rito.git",
    "directory": "packages/rito"
  },
  "keywords": [
    "epub",
    "canvas",
    "renderer",
    "ebook",
    "typesetting",
    "layout",
    "pagination",
    "reader"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./advanced": {
      "import": "./dist/advanced.mjs",
      "types": "./dist/advanced.d.mts"
    },
    "./selection": {
      "import": "./dist/selection.mjs",
      "types": "./dist/selection.d.mts"
    },
    "./search": {
      "import": "./dist/search.mjs",
      "types": "./dist/search.d.mts"
    },
    "./annotations": {
      "import": "./dist/annotations.mjs",
      "types": "./dist/annotations.d.mts"
    },
    "./position": {
      "import": "./dist/position.mjs",
      "types": "./dist/position.d.mts"
    },
    "./a11y": {
      "import": "./dist/a11y.mjs",
      "types": "./dist/a11y.d.mts"
    },
    "./dom": {
      "import": "./dist/dom.mjs",
      "types": "./dist/dom.d.mts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "happy-dom": "^20.8.9",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  }
}
