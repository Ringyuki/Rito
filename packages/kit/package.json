{
  "name": "@ritojs/kit",
  "type": "module",
  "version": "0.6.0",
  "description": "Framework-agnostic controller, overlays, and transitions for @ritojs/core",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "homepage": "https://github.com/Ringyuki/Rito/tree/master/packages/kit#readme",
  "bugs": {
    "url": "https://github.com/Ringyuki/Rito/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ringyuki/Rito.git",
    "directory": "packages/kit"
  },
  "keywords": [
    "epub",
    "canvas",
    "reader",
    "controller",
    "overlay",
    "transition"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./keyboard": {
      "import": "./dist/keyboard.mjs",
      "types": "./dist/keyboard.d.mts"
    },
    "./storage": {
      "import": "./dist/storage.mjs",
      "types": "./dist/storage.d.mts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ritojs/core": "workspace:^"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  }
}
