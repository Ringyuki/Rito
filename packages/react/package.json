{
  "name": "@ritojs/react",
  "type": "module",
  "version": "0.7.0",
  "description": "React hooks and components for @ritojs/core",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "homepage": "https://github.com/Ringyuki/Rito/tree/master/packages/react#readme",
  "bugs": {
    "url": "https://github.com/Ringyuki/Rito/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ringyuki/Rito.git",
    "directory": "packages/react"
  },
  "keywords": [
    "epub",
    "canvas",
    "reader",
    "react",
    "hooks"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./hooks": {
      "import": "./dist/hooks.mjs",
      "types": "./dist/hooks.d.mts"
    },
    "./components": {
      "import": "./dist/components.mjs",
      "types": "./dist/components.d.mts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ritojs/core": "workspace:^",
    "@ritojs/kit": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  }
}
